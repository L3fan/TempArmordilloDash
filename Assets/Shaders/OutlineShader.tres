code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 OutlineColor : source_color;
uniform float Width;



void fragment() {
	vec4 n_out43p0;
// Texture2D:43
	n_out43p0 = texture(TEXTURE, UV);
	float n_out43p4 = n_out43p0.a;


// ColorParameter:47
	vec4 n_out47p0 = OutlineColor;


	vec3 n_out46p0;
// If:46
	float n_in46p1 = 0.00000;
	float n_in46p2 = 0.00001;
	vec3 n_in46p5 = vec3(0.00000, 0.00000, 0.00000);
	if(abs(n_out43p4 - n_in46p1) < n_in46p2)
	{
		n_out46p0 = vec3(n_out47p0.xyz);
	}
	else if(n_out43p4 < n_in46p1)
	{
		n_out46p0 = n_in46p5;
	}
	else
	{
		n_out46p0 = vec3(n_out43p0.xyz);
	}


// Input:10
	vec2 n_out10p0 = UV;


// VectorCompose:5
	float n_in5p0 = 1.00000;
	float n_in5p1 = 0.00000;
	vec2 n_out5p0 = vec2(n_in5p0, n_in5p1);


// FloatParameter:6
	float n_out6p0 = Width;


// Input:7
	vec2 n_out7p0 = TEXTURE_PIXEL_SIZE;


// VectorOp:8
	vec2 n_out8p0 = vec2(n_out6p0) * n_out7p0;


// VectorOp:9
	vec2 n_out9p0 = n_out5p0 * n_out8p0;


// VectorOp:11
	vec2 n_out11p0 = n_out10p0 - n_out9p0;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(TEXTURE, n_out11p0);
	float n_out3p4 = n_out3p0.a;


// Input:18
	vec2 n_out18p0 = UV;


// VectorCompose:16
	float n_in16p0 = -1.00000;
	float n_in16p1 = 0.00000;
	vec2 n_out16p0 = vec2(n_in16p0, n_in16p1);


// VectorOp:19
	vec2 n_out19p0 = n_out16p0 * n_out8p0;


// VectorOp:21
	vec2 n_out21p0 = n_out18p0 - n_out19p0;


	vec4 n_out20p0;
// Texture2D:20
	n_out20p0 = texture(TEXTURE, n_out21p0);
	float n_out20p4 = n_out20p0.a;


// FloatOp:40
	float n_out40p0 = n_out3p4 + n_out20p4;


// Input:27
	vec2 n_out27p0 = UV;


// VectorCompose:25
	float n_in25p0 = 0.00000;
	float n_in25p1 = 1.00000;
	vec2 n_out25p0 = vec2(n_in25p0, n_in25p1);


// VectorOp:28
	vec2 n_out28p0 = n_out25p0 * n_out8p0;


// VectorOp:30
	vec2 n_out30p0 = n_out27p0 - n_out28p0;


	vec4 n_out29p0;
// Texture2D:29
	n_out29p0 = texture(TEXTURE, n_out30p0);
	float n_out29p4 = n_out29p0.a;


// Input:36
	vec2 n_out36p0 = UV;


// VectorCompose:34
	float n_in34p0 = 0.00000;
	float n_in34p1 = -1.00000;
	vec2 n_out34p0 = vec2(n_in34p0, n_in34p1);


// VectorOp:37
	vec2 n_out37p0 = n_out34p0 * n_out8p0;


// VectorOp:39
	vec2 n_out39p0 = n_out36p0 - n_out37p0;


	vec4 n_out38p0;
// Texture2D:38
	n_out38p0 = texture(TEXTURE, n_out39p0);
	float n_out38p4 = n_out38p0.a;


// FloatOp:41
	float n_out41p0 = n_out29p4 + n_out38p4;


// FloatOp:42
	float n_out42p0 = n_out40p0 + n_out41p0;


// FloatOp:45
	float n_out45p0 = n_out42p0 + n_out43p4;


// Output:0
	COLOR.rgb = n_out46p0;
	COLOR.a = n_out45p0;


}
"
