; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

ss2d/version="3.3.1"

[application]

config/name="Armordillo_Dash"
run/main_scene="uid://c4e38trnicacr"
config/features=PackedStringArray("4.5", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://dkuip5khy1q4d"

[autoload]

GameManager="*res://Assets/Scripts/GameManager.cs"
Settings="*res://Assets/Scripts/Settings.cs"
LevelManager="*res://Assets/Scripts/LevelManager.cs"
Save="*res://Assets/Scripts/Save.cs"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Armordillo_Dash"

[editor]

naming/default_signal_callback_name="_On{node_name}{signal_name}"
naming/default_signal_callback_to_self_name="_On{signal_name}"
naming/scene_name_casing=1
naming/script_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/RoundedPolygon2D/plugin.cfg", "res://addons/parallax2d_preview/plugin.cfg", "res://addons/radial_progress/plugin.cfg", "res://addons/rmsmartshape/plugin.cfg")

[global_group]

Player=""

